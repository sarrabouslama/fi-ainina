# =========================
# GENERAL
# =========================
ENV=development
DEBUG=true
APP_NAME=fi-ainina
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production

# =========================
# LLM CONFIG
# =========================
LLM_PROVIDER=ollama

# Ollama (local - recommended)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# OpenAI (optional alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql://postgres:password@localhost:5432/fi_ainina

# =========================
# COMPUTER VISION
# =========================
DEEPFACE_DISTANCE_METRIC=cosine
MEDIAPIPE_CONFIDENCE=0.5
INACTIVITY_THRESHOLD=60
FALL_TIME_THRESHOLD=10
CAMERA_INDEX=0

# =========================
# VOICE
# =========================
STT_PROVIDER=whisper
WHISPER_MODEL=base

TTS_PROVIDER=coqui
COQUI_DEVICE=cpu

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# =========================
# ALERT SYSTEM
# =========================
ALERT_EMAIL_FROM=alerts@aicompanion.local
ALERT_EMAIL_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
ALERT_WEBHOOK_URL=
ALERT_TIMEOUT=120

# =========================
# LOGGING
# =========================
LOG_LEVEL=INFO

# =========================
# FRONTEND
# =========================
VITE_API_URL=http://localhost:5173
