# ============================================================
# fi-ainina AI — Root Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fi-ainina
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql://postgres_user:changeme_strong_password@postgres:5432/fi-ainina

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- JWT Auth (shared across services) ---
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Service URLs (internal docker network) ---
LLM_SERVICE_URL=http://llm_service:8001
VOICE_SERVICE_URL=http://voice_service:8002
FALL_SERVICE_URL=http://fall_detection_service:8003
EMOTION_SERVICE_URL=http://emotion_service:8004
ALERT_SERVICE_URL=http://alert_service:8005

# --- Redis Channels (shared contract between services) ---
REDIS_CHANNEL_FALL=fall_events
REDIS_CHANNEL_EMOTION=emotion_events
REDIS_CHANNEL_INACTIVITY=inactivity_events
REDIS_CHANNEL_ALERTS=alerts

# --- Clip storage (shared volume) ---
CLIPS_DIR=/app/clips
