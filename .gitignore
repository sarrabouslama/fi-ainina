# ============================================================
# ElderCare AI — .gitignore
# ============================================================

# Environment files — NEVER commit these
.env
services/**/.env
frontend/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
services/**/.venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
*.pyc

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.log
npm-debug.log*

# Docker
*.pid

# Video clips & large files
*.mp4
*.avi
*.mkv
clips/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
logs/
*.log

# Models (too large for git)
*.pt
*.pth
*.onnx
*.pkl
models/

# OS
Thumbs.db
