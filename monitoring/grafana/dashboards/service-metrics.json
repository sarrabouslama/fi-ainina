{
  "id": null,
  "uid": "fia-service-metrics",
  "title": "FiAinina Service Metrics",
  "tags": ["monitoring"],
  "timezone": "browser",
  "schemaVersion": 37,
  "version": 0,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Prometheus target status",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 4},
      "targets": [
        {
          "expr": "up{job=~\".*\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests Total",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 9},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (endpoint)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "list"}}
    }
  ],
  "folders": [],
  "gnetId": null,
  "time": {"from": "now-1h", "to": "now"}
}
