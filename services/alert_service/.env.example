# ═══════════════════════════════════════════════════════════════════════════
# FiAinina Alert Service Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials

# ─────────────────────────────────────────────────────────────────────────
# Core Services
# ─────────────────────────────────────────────────────────────────────────

# Redis (pub/sub for events)
REDIS_URL=redis://redis:6379
ALERT_REDIS_CHANNELS=fall_events,emotion_events,inactivity_events

# PostgreSQL (alert_log, user lookups)
DATABASE_URL=postgresql://postgres:your_password@postgres:5432/fi_ainina

# ─────────────────────────────────────────────────────────────────────────
# Email Configuration (SMTP)
# Mailtrap sandbox example. Use the credentials from your Mailtrap inbox.
# ─────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_character_app_password
SMTP_FROM_NAME=FiAinina Alerts
SMTP_FROM_EMAIL=Your_email@gmail.com
SMTP_TLS=true
SMTP_SSL=false
SMTP_TIMEOUT=30
ALERT_TEST_EMAIL_RECIPIENTS=recipient@example.com
# ─────────────────────────────────────────────────────────────────────────
# WhatsApp Configuration (Twilio)
# Get credentials from: https://www.twilio.com/console
# ─────────────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_CHANNEL=whatsapp
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional TLS settings for local environments with custom CA stores.
TWILIO_SSL_VERIFY=true
TWILIO_CA_BUNDLE=
ALERT_TEST_WHATSAPP_RECIPIENTS=whatsapp:+1234567890

# ─────────────────────────────────────────────────────────────────────────
# Alert Configuration
# ─────────────────────────────────────────────────────────────────────────

# Cooldown between identical alerts (minutes)
# E.g., only 1 "fall_detected" alert per user per 5 minutes
ALERT_COOLDOWN_MINUTES=5

# WebSocket server port
WS_PORT=8005

# ─────────────────────────────────────────────────────────────────────────
# Feature Flags
# Set to "false" to disable a channel
# ─────────────────────────────────────────────────────────────────────────

ENABLE_EMAIL=true
ENABLE_SMS=true
ENABLE_WEBSOCKET=true

# ─────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ═══════════════════════════════════════════════════════════════════════════
# Setup Instructions
# ═══════════════════════════════════════════════════════════════════════════

# 1. Mailtrap SMTP (recommended for testing):
#    - Open your Mailtrap sandbox inbox
#    - Copy SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS into .env
#    - For port 2525, keep SMTP_TLS=false and SMTP_SSL=false
#    - For port 587, use SMTP_TLS=true and SMTP_SSL=false

# 2. Twilio WhatsApp Sandbox:
#    - Sign up: https://www.twilio.com/console
#    - Get your Account SID and Auth Token
#    - Open Messaging > Try it out > Send a WhatsApp message
#    - Join the sandbox from your phone before testing
#    - Keep TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 for sandbox
#    - Set ALERT_TEST_WHATSAPP_RECIPIENTS=whatsapp:+your_phone_number

# 3. Test Locally:
#    cp .env.example .env
#    # Edit .env with your credentials
#    docker-compose up alert_service
#    # Send test alert:
#    curl -X POST http://localhost:8005/alerts/test \
#      -H "Content-Type: application/json" \
#      -d '{
#        "event_type": "fall_detected",
#        "user_id": "elder_001",
#        "severity": "high",
#        "metadata": {"confidence": 0.95}
#      }'

# ═══════════════════════════════════════════════════════════════════════════
