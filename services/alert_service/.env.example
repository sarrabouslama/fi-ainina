# ═══════════════════════════════════════════════════════════════════════════
# FiAinina Alert Service Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials

# ─────────────────────────────────────────────────────────────────────────
# Core Services
# ─────────────────────────────────────────────────────────────────────────

# Redis (pub/sub for events)
REDIS_URL=redis://redis:6379

# PostgreSQL (alert_log, user lookups)
DATABASE_URL=postgresql://postgres:your_password@postgres:5432/fi_ainina

# ─────────────────────────────────────────────────────────────────────────
# Email Configuration (SMTP)
# For Gmail: https://myaccount.google.com/apppasswords
# For other providers: use your SMTP credentials
# ─────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=FiAinina Alerts

# ─────────────────────────────────────────────────────────────────────────
# SMS Configuration (Twilio)
# Get credentials from: https://www.twilio.com/console
# ─────────────────────────────────────────────────────────────────────────

TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# ─────────────────────────────────────────────────────────────────────────
# Alert Configuration
# ─────────────────────────────────────────────────────────────────────────

# Cooldown between identical alerts (minutes)
# E.g., only 1 "fall_detected" alert per user per 5 minutes
ALERT_COOLDOWN_MINUTES=5

# WebSocket server port
WS_PORT=8005

# ─────────────────────────────────────────────────────────────────────────
# Feature Flags
# Set to "false" to disable a channel
# ─────────────────────────────────────────────────────────────────────────

ENABLE_EMAIL=true
ENABLE_SMS=true
ENABLE_WEBSOCKET=true

# ─────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ═══════════════════════════════════════════════════════════════════════════
# Setup Instructions
# ═══════════════════════════════════════════════════════════════════════════

# 1. Gmail SMTP (recommended for testing):
#    - Enable 2FA on your Google account
#    - Go to: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer"
#    - Copy the generated password to SMTP_PASS
#
#    SMTP_HOST=smtp.gmail.com
#    SMTP_PORT=587
#    SMTP_USER=your-email@gmail.com
#    SMTP_PASS=your-16-char-password

# 2. Twilio SMS (production):
#    - Sign up: https://www.twilio.com/console
#    - Get your Account SID and Auth Token
#    - Get a Twilio phone number for TWILIO_FROM
#    - Each SMS costs ~$0.0075 USD

# 3. Test Locally:
#    cp .env.example .env
#    # Edit .env with your credentials
#    docker-compose up alert_service
#    # Send test alert:
#    curl -X POST http://localhost:8005/alerts/test \
#      -H "Content-Type: application/json" \
#      -d '{
#        "event_type": "fall_detected",
#        "user_id": "elder_001",
#        "severity": "high",
#        "metadata": {"confidence": 0.95}
#      }'

# ═══════════════════════════════════════════════════════════════════════════
