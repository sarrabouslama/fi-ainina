# P3 — Fall Detection Service
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Detection thresholds (all configurable via API)
FALL_CONFIDENCE_THRESHOLD=0.75
FALL_PERSISTENCE_SECONDS=0.5
VELOCITY_THRESHOLD=200
BODY_RATIO_LYING=1.2
BODY_RATIO_SITTING_MIN=0.5
BODY_RATIO_SITTING_MAX=0.9
BODY_ANGLE_STANDING_MIN=70

# Confidence weights [angle, ratio, velocity, head, persistence]
CONFIDENCE_WEIGHTS=0.25,0.20,0.30,0.10,0.15

# Camera quality
CAMERA_QUALITY_MIN_LANDMARKS=25
CAMERA_QUALITY_MIN_HEIGHT_PX=150

# Clips
CLIPS_DIR=/app/clips
CLIP_PRE_SECONDS=10
CLIP_POST_SECONDS=5

# Redis channels (must match root .env)
REDIS_CHANNEL_FALL=fall_events
